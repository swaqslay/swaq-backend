# ── App ──────────────────────────────────────────────────────
APP_NAME=Swaq AI
APP_ENV=development

# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── JWT ──────────────────────────────────────────────────────
