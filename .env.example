# ============================================================
# Swaq AI — Environment Configuration Template
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="Swaq AI"
APP_ENV=development # development, staging, or production

# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# ── JWT ──────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
FREE_DAILY_SCAN_LIMIT=3

# ── AI APIs ─────────────────────────────────────────────────
# AI_PROVIDER: "gemini" (Google Gemini 2.0 Flash) or "groq" (Llama 4 Maverick)
# Primary provider is tried first; if it fails, falls back to the other.
AI_PROVIDER=gemini

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────
# Paste the fully serialized JSON object of your Service Account credential here.
# E.g. '{"type": "service_account", "project_id": "...", ...}'
GOOGLE_CREDENTIALS_JSON='your_json_string_here'

# Get Gemini key at: https://aistudio.google.com/apikey (optional if not using Vertex)
# Model: gemini-2.0-flash-001
GEMINI_API_KEY=your_gemini_api_key_here

# Get Groq key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.2-11b-vision-preview

# ── Nutrition Database (USDA) ────────────────────────────────
# Get key at: https://fdc.nal.usda.gov/api-key-signup
USDA_API_KEY=your_usda_api_key_here

# ── Database ─────────────────────────────────────────────────
# Local dev: SQLite (no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./swaq.db

# Production (Supabase):
# Use the Connection String (URI) from Supabase Transaction Pooler (Port 6543)
# Format: postgresql://postgres.[ID]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
# Note: DATABASE_URL should use postgresql+asyncpg:// prefix locally if connecting to Postgres.
# SUPABASE_DATABASE_URL=your_supabase_uri_here

SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Redis Cache (Optional) ───────────────────────────────────
# Get at: https://upstash.com (free tier)
REDIS_URL=your_redis_url_here

# ── Image Storage (Backblaze B2) ────────────────────────────
# Endpoint format: https://s3.<region>.backblazeb2.com
# Get credentials at: https://secure.backblaze.com/app_keys.htm
BACKBLAZE_B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
BACKBLAZE_B2_ACCESS_KEY=your_b2_access_key
BACKBLAZE_B2_SECRET_KEY=your_b2_secret_key
BACKBLAZE_B2_BUCKET=swaq-images
BACKBLAZE_B2_REGION=us-west-004

# ── Image Storage (Cloudflare R2 — reserved) ────────────────
CLOUDFLARE_R2_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key
CLOUDFLARE_R2_BUCKET=swaq-images
